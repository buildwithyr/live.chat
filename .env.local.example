# Supabase – zu finden unter: Supabase Dashboard → Project Settings → API
# Diese Werte sind oeffentlich (anon key) und duerfen im Browser landen.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push: oeffentlicher VAPID-Key (sicher im Browser).
# Erzeugen mit:  npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
